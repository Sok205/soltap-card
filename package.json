{
  "name": "soltap",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build && pnpm --filter card-sdk build",
    "test": "pnpm --filter '*' test && cargo test",
    "init-collection": "pnpm tsx scripts/init-collection.ts",
    "check-config": "pnpm tsx scripts/check-config.ts"
  },
  "pnpm": {
    "overrides": {
      "vite-plugin-solid>vite": "^6.4.1",
      "h3": "^1.15.6",
      "vite": ">=6.4.2",
      "uuid": "^11.1.1",
      "@metaplex-foundation/mpl-core>@noble/hashes": "~1.8.0",
      "@noble/hashes": "~1.8.0"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@metaplex-foundation/mpl-core>@noble/hashes": "~1.8.0"
      }
    },
    "packageExtensions": {
      "@noble/hashes@2.x": {
        "exports": {
          "./sha3": "./sha3.js"
        }
      }
    },
    "patchedDependencies": {
      "@noble/hashes@2.2.0": "patches/@noble__hashes@2.2.0.patch"
    }
  },
  "devDependencies": {
    "@iarna/toml": "^2.2.5",
    "@metaplex-foundation/mpl-core": "1.1.2",
    "@metaplex-foundation/umi": "^0.9.0",
    "@metaplex-foundation/umi-bundle-defaults": "^0.9.0",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.5",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
