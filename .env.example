FEE_PAYER_KEYPAIR_B58=
OWNER_UPDATE_AUTHORITY_KEYPAIR_B58=
HELIUS_API_KEY=
IRYS_PRIVATE_KEY=

# Server-side (SSR / API routes): full internal indexer URL. Never bundled
# into the browser. Used by fetchStats, fetchHistory, and getCurrentEdition.
INDEXER_URL=http://localhost:8787

# Client-side (browser): public-facing indexer URL. Must be set at build time
# because Vite inlines VITE_* env vars into the browser bundle. For local dev,
# leave unset and the client will fall back to http://localhost:8787.
VITE_INDEXER_URL=

# Public base URL for on-chain metadata URIs. REQUIRED in production.
# In dev, falls back to request Host header (ngrok/cloudflare tunnel friendly).
PUBLIC_BASE_URL=

# Optional: Vercel KV / Upstash Redis REST credentials for persistent rate limit.
# If unset, in-memory rate limit is used (only safe for local dev / single-instance).
KV_REST_API_URL=
KV_REST_API_TOKEN=
